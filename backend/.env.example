# ============================================================
# backend/.env.example — Environment Variable Reference
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ============================================================

# PostgreSQL connection string
# Docker Compose: use hostname "db" (the service name)
# Local dev:      use "localhost"
DATABASE_URL=postgres://pmuser:pmpassword@db:5432/passwordmanager?sslmode=disable

# JWT signing secret — must be at least 32 random bytes
# Generate: openssl rand -base64 32
JWT_SECRET=replace-with-at-least-32-random-bytes-here

# AES-256 encryption key — must be EXACTLY 32 bytes when base64-decoded
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=replace-with-exactly-32-byte-base64-encoded-key=

# HTTP server port
PORT=8080

# Environment: "development" or "production"
ENVIRONMENT=development

# Rate limit for the login endpoint (per IP)
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW=60
